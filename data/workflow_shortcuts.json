{
  "keymap": [
    {
      "section": "Project Navigation",
      "items": [
        { "keys": "⌃⌥O", "description": "Open Oracle of Secrets" },
        { "keys": "⌃⌥Y", "description": "Open YAZE Editor" },
        { "keys": "⌃⌥G", "description": "Open LazyGit" },
        { "keys": "fp <name>", "description": "Fuzzy Find Project (Zsh)" }
      ]
    },
    {
      "section": "Window Management",
      "items": [
        { "keys": "⌥G", "description": "Toggle Zen Mode (Gaps)" },
        { "keys": "⌥B", "description": "Balance Layout" },
        { "keys": "⌃⌥←/→", "description": "Prev/Next Space" },
        { "keys": "⌃⌥R", "description": "Rotate Layout" }
      ]
    },
    {
      "section": "System",
      "items": [
        { "keys": "⌃⌥R", "description": "Restart Services" },
        { "keys": "syshelp", "description": "Show System Help" }
      ]
    },
    {
      "section": "Syshelp & Panel",
      "items": [
        { "keys": "⌃⌥H", "description": "Toggle Syshelp Panel (overlay)" },
        { "keys": "⌃⌥P", "description": "Open Barista Control Panel" },
        { "keys": "whichkey", "description": "Toggle WhichKey HUD" }
      ]
    }
  ],
  "actions": [
    { "id": "reload_bar", "title": "Reload SketchyBar", "selector": "reloadBar:" },
    { "id": "launch_yaze", "title": "Launch YAZE", "selector": "launchYaze:" },
    { "id": "focus_emacs", "title": "Focus Emacs", "selector": "focusEmacsSpace:" },
    { "id": "syshelp_panel", "title": "Toggle Syshelp Panel", "selector": "openKeyboardOverlay:" },
    { "id": "syshelp_cli", "title": "Open syshelp", "selector": "openSysManual:" },
    { "id": "whichkey_toggle", "title": "Toggle WhichKey HUD", "command": "/opt/homebrew/opt/sketchybar/bin/sketchybar --trigger whichkey_toggle" },
    { "id": "open_control_panel", "title": "Open Control Panel", "selector": "openControlPanel:" }
  ],
  "docs": [
    { "id": "oracle", "title": "Oracle Workflow", "path": "~/src/hobby/oracle-of-secrets/Docs/oracle.org" },
    { "id": "handoff", "title": "Handoff Notes", "path": "~/.config/sketchybar/HANDOFF.md" }
  ]
}

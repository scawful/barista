{
  "name": "barista",
  "description": "SketchyBar configuration with Yaze integration",
  "yaze_path": "${HOME}/src/hobby/yaze",
  "build_path": "${HOME}/src/hobby/yaze/build/presets/mac-ai-fast/bin/Debug",
  "binary_name": "yaze",
  "menu_items": [
    {
      "name": "Launch Yaze",
      "action": "open",
      "path": "/Applications/yaze.app"
    },
    {
      "name": "Open Yaze Repo",
      "action": "open_path",
      "path": "${HOME}/src/hobby/yaze"
    },
    {
      "name": "Focus Emacs Space",
      "action": "yabai_space_focus",
      "app": "Emacs"
    }
  ],
  "workflows": {
    "rom_hacking": {
      "enabled": true,
      "docs_path": "${HOME}/src/docs/workflow/rom-hacking.org",
      "roms_path": "${HOME}/src/hobby/yaze/roms"
    }
  }
}
